# Follow Readme for instructions on where to get these files.
BF_FLUXER_TOKEN="" # Also supports BF_FLUXER_TOKEN_FILE for file-based secrets management, e.g. with Docker secrets
BF_FLUXER_APP_ID=""
BF_DISCORD_TOKEN="" # Also supports BF_DISCORD_TOKEN_FILE for file-based secrets management, e.g. with Docker secrets
BF_DISCORD_APP_ID=""

BF_COMMAND_PREFIX="!b "

# Self-hosted instance configuration (optional — defaults work for the official fluxer.app instance)
# Set BF_FLUXER_DOMAIN to your instance's domain if you're running a self-hosted Fluxer server.
# The API base and web base are derived automatically from this domain using the standard
# operator stack conventions (docs.fluxer.app/operator), but can be overridden if needed.
# These can also be set via CLI flags: --fluxer-domain, --fluxer-api-base, --fluxer-web-base
BF_FLUXER_DOMAIN="fluxer.app"
# BF_FLUXER_API_BASE="https://api.fluxer.app"     # default for fluxer.app; self-hosted: https://<domain>/api
# BF_FLUXER_WEB_BASE="https://web.fluxer.app"     # default for fluxer.app; self-hosted: https://<domain>

# Owner UserID for both Fluxer and Discord, used for Debugging commands like %list all
BF_FLUXER_OWNER_ID=""
BF_DISCORD_OWNER_ID=""

# Temporary. Until Fluxer supports slash commands, this just helps cleans up command spam, The invoking command is still displayed in the footer w/ timestamp.
BF_DELETE_INVOCATION="false"

# Health Check
# These URLs are used to push health status updates to an uptime monitoring service. Replace with actual URLs if you want to enable this feature.
BF_DISCORD_HEALTH_URL=""
BF_FLUXER_HEALTH_URL=""

# Supported values: 'sqlite', 'postgres'
BF_DB_DIALECT='sqlite'
# Database configuration for PostgreSQL (ignored if using SQLite)
BF_DB_NAME='bifrost'
BF_DB_USER='root'
BF_DB_PASS=''
BF_DB_HOST='localhost'
BF_DB_PORT='5432'

BF_METRICS_PORT='9091'
BF_QUEUE_TTL_MS='' # Optional: Time in milliseconds which messages that are scheduled to be relayed to Flux from Discord are kept (This is a temporary measure as sometimes flux expirences instability, this keeps a short record of stuff to relay when the bot comes online for shorter outages.)

# Set by CI/CD — override manually if needed
GIT_COMMIT=''
REPO_URL=''
